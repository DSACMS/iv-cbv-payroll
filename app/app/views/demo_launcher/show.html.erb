<% content_for :title, "Emmy Launcher" %>
<div class="grid-col-12 demo-launcher">
  <h1>Emmy Launcher</h1>
  <div class="usa-hint demo-launcher__usa-hint">Configure settings and launch Emmy in a new tab.</div>
  <%= form_with(url: "/demo", method: :post, builder: UswdsFormBuilder, html: { class: "usa-form usa-form--large" }, data: { turbo: false, controller: "demo-launcher" }) do |f| %>
    <div class="demo-launcher__two-col">
      <div class="demo-launcher__left-col">
        <div class="demo-launcher__flow-type">
          <h3 class="demo-launcher__section-label">Flow type</h3>
          <div class="demo-launcher__flow-type-radios">
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio" name="flow_type" id="flow_type_activity" value="activity" checked data-action="demo-launcher#selectFlowType">
              <label class="usa-radio__label" for="flow_type_activity">CE</label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio" name="flow_type" id="flow_type_cbv" value="cbv" data-action="demo-launcher#selectFlowType">
              <label class="usa-radio__label" for="flow_type_cbv">Income</label>
            </div>
          </div>
        </div>
        <div class="demo-launcher__launch">
          <h3 class="demo-launcher__section-label">Launch</h3>
          <div class="demo-launcher__launch-buttons">
            <button type="submit" name="launch_type" value="tokenized" formtarget="_blank" class="usa-button demo-launcher__launch-button">
              Tokenized
            </button>
            <button type="submit" name="launch_type" value="generic" formtarget="_blank" class="usa-button usa-button--outline demo-launcher__launch-button" data-demo-launcher-target="genericButton">
              Generic
            </button>
          </div>
        </div>
        <div class="demo-launcher__test-scenarios" data-demo-launcher-target="ceOnly">
          <h3 class="demo-launcher__section-label">Test Scenarios</h3>
          <div class="demo-launcher__scenario-radios">
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_none" value="" checked
                     data-action="demo-launcher#selectScenario">
              <label class="usa-radio__label" for="test_scenario_none">None</label>
            </div>

            <h4 class="demo-launcher__section-label">NSC Test Scenarios</h4>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_lynette" value="lynette"
                     data-action="demo-launcher#selectScenario"
                     data-reporting-window-start="10/01/2024"
                     data-reporting-window-months="2">
              <label class="usa-radio__label" for="test_scenario_lynette">
                <strong>Lynette Oyola</strong>
                <span class="demo-launcher__scenario-desc">Currently enrolled (1 school)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_rick" value="rick"
                     data-action="demo-launcher#selectScenario"
                     data-reporting-window-start="10/01/2024"
                     data-reporting-window-months="2">
              <label class="usa-radio__label" for="test_scenario_rick">
                <strong>Rick Banas</strong>
                <span class="demo-launcher__scenario-desc">Currently enrolled (2 schools)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_dominique" value="dominique"
                     data-action="demo-launcher#selectScenario"
                     data-reporting-window-start="06/01/2024"
                     data-reporting-window-months="2">
              <label class="usa-radio__label" for="test_scenario_dominique">
                <strong>Dominique Ricardo</strong>
                <span class="demo-launcher__scenario-desc">Not currently enrolled (enrollments outside window)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_linda" value="linda"
                     data-action="demo-launcher#selectScenario">
              <label class="usa-radio__label" for="test_scenario_linda">
                <strong>Linda Cooper</strong>
                <span class="demo-launcher__scenario-desc">No NSC record found</span>
              </label>
            </div>

            <h4 class="demo-launcher__section-label">Fake Test Scenarios</h4>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_partial_enrollment_sam" value="partial_enrollment_sam"
                     data-action="demo-launcher#selectScenario">
              <label class="usa-radio__label" for="test_scenario_partial_enrollment_sam">
                <strong>Sam Testuser</strong>
                <span class="demo-launcher__scenario-desc">Less than half-time enrollment (2 schools)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_partial_enrollment_ziggy" value="partial_enrollment_ziggy"
                     data-action="demo-launcher#selectScenario">
              <label class="usa-radio__label" for="test_scenario_partial_enrollment_ziggy">
                <strong>Ziggy Testuser</strong>
                <span class="demo-launcher__scenario-desc">Less than half-time enrollment (1 school)</span>
              </label>
            </div>
          </div>
        </div>
      </div>
      <hr class="demo-launcher__mobile-divider">
      <div class="demo-launcher__settings">
        <h2>Settings</h2>
        <%= render DemoLauncher::SettingComponent.new(title: "Agency", hint: "Select the agency the flow will use.") do %>
          <select class="usa-select" name="client_agency_id" id="client_agency_id">
            <% Rails.application.config.client_agencies.client_agency_ids.each do |agency_id| %>
              <option value="<%= agency_id %>" <%= "selected" if agency_id == "sandbox" %>><%= agency_id %></option>
            <% end %>
          </select>
        <% end %>
        <div data-demo-launcher-target="ceOnly">
          <%= render DemoLauncher::SettingComponent.new(title: "Reporting window", hint: "Select the type of flow you want to create. This determines the number of months in the reporting window.") do %>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio" name="reporting_window" id="reporting_window_application" value="application" <%= "checked" unless params[:reporting_window] == "renewal" %> data-action="demo-launcher#selectWindow">
              <label class="usa-radio__label" for="reporting_window_application">Application</label>
            </div>
            <div data-demo-launcher-target="monthButtons" class="demo-launcher__month-buttons margin-top-1">
              <button type="button" class="usa-button" data-months="1" data-action="demo-launcher#selectMonths">1 month
              </button>
              <button type="button" class="usa-button" data-months="2" data-action="demo-launcher#selectMonths">2 months
              </button>
              <button type="button" class="usa-button" data-months="3" data-action="demo-launcher#selectMonths">3 months
              </button>
              <div class="usa-hint demo-launcher__month-buttons-hint">The application reporting window is configurable by the
                state.
              </div>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio" name="reporting_window" id="reporting_window_renewal" value="renewal" <%= "checked" if params[:reporting_window] == "renewal" %> data-action="demo-launcher#selectWindow">
              <label class="usa-radio__label" for="reporting_window_renewal">Renewal</label>
            </div>
            <div class="usa-hint demo-launcher__separator">-- or --</div>
            <div class="demo-launcher__inline-field">
              <input class="usa-input usa-input--sm" type="number" name="reporting_window_months"
                     id="reporting_window_months" min="1" max="99" autocomplete="off"
                     value="<%= params[:reporting_window_months] %>"
                     data-demo-launcher-target="monthsInput">
              <span>months</span>
              <span class="demo-launcher__hint-toggle" data-action="click->demo-launcher#toggleInlineHint"><svg class="usa-icon" aria-hidden="true" focusable="false" role="img"><use href="<%= asset_path("@uswds/uswds/dist/img/sprite.svg#info") %>"></use></svg></span>
            </div>
            <div class="usa-hint demo-launcher__setting-hint" hidden>
              Specify the reporting window manually.
            </div>
          <% end %>
          <%= render DemoLauncher::SettingComponent.new(
            title: "Reporting window start",
            hint: "Specify when the reporting window begins. When set, the window runs forward from the beginning of the selected month. Leave blank to use the default (window ends at the latest completed month)."
          ) do %>
            <div class="usa-date-picker" data-demo-launcher-target="datePickerWrapper">
              <input
                class="usa-input"
                type="text"
                name="reporting_window_start"
                id="reporting_window_start"
                autocomplete="off"
              >
            </div>
          <% end %>
        </div>
        <%= render DemoLauncher::SettingComponent.new(title: "Session timeout", hint: "Specify the number of minutes it should take for the session to time out. Note: the warning modal appears 5 min before timeout, so use 6 or higher to avoid an immediate warning.") do %>
          <div class="demo-launcher__inline-field">
            <input class="usa-input usa-input--sm" type="number" name="demo_timeout"
                   id="demo_timeout" min="1" max="999" autocomplete="off"
                   value="<%= params[:demo_timeout] || 30 %>">
            <span>minutes</span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
