<% content_for :title, "Emmy Launcher" %>
<div class="grid-col-12 advanced-launcher">
  <h1>Emmy Launcher 🏆🚀</h1>
  <div class="usa-hint advanced-launcher__usa-hint">Configure settings and launch Emmy in a new tab.</div>
  <%= form_with(url: "/launcher/advanced", method: :post, builder: UswdsFormBuilder, html: { class: "usa-form usa-form--large" }, data: { turbo: false, controller: "advanced-launcher", "advanced-launcher-agency-activity-types-value": agency_activity_types.to_json, action: "input->advanced-launcher#invalidateShareLink change->advanced-launcher#invalidateShareLink" }) do |f| %>
    <div class="advanced-launcher__two-col">
      <div class="advanced-launcher__left-col">
        <section class="advanced-launcher__test-scenarios">
          <h2><%= t(".launch_configuration.title") %></h2>
          <div class="advanced-launcher__launch-mode-radios">
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="launch_mode" id="launch_mode_individual" value="individual" checked
                     data-action="advanced-launcher#selectLaunchMode">
              <label class="usa-radio__label" for="launch_mode_individual"><%= t(".launch_mode.individual") %></label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="launch_mode" id="launch_mode_household" value="household"
                     data-advanced-launcher-target="householdModeRadio"
                     data-action="advanced-launcher#selectLaunchMode">
              <label class="usa-radio__label" for="launch_mode_household"><%= t(".launch_mode.household") %></label>
            </div>
          </div>
          <p class="usa-hint" hidden data-advanced-launcher-target="householdUnavailableHint"><%= t(".household.unavailable") %></p>

          <div data-advanced-launcher-target="individualConfiguration">
            <div data-advanced-launcher-target="ceOnly">
              <div class="usa-accordion usa-accordion--bordered advanced-launcher__pre-populated-activities">
                <h3 class="usa-accordion__heading">
                  <button type="button" class="usa-accordion__button"
                          id="pre-populated-activities-button"
                          aria-expanded="true"
                          aria-controls="pre-populated-activities-content">
                    <%= t(".individual.pre_populated_activities") %>
                  </button>
                </h3>
                <div id="pre-populated-activities-content" class="usa-accordion__content" aria-labelledby="pre-populated-activities-button">
                  <%= render "pre_populated_activities" %>
                </div>
              </div>
            </div>
          </div>

          <div hidden data-advanced-launcher-target="householdConfiguration">
            <h3><%= t(".household.title") %></h3>
            <p class="usa-hint"><%= t(".household.description") %></p>
            <p class="usa-hint" hidden data-advanced-launcher-target="householdSelectionHint"><%= t(".household.selection_hint") %></p>
            <div class="advanced-launcher__archetypes">
            <% Launcher::HouseholdScenario.archetypes.each_key do |archetype_key| %>
              <div class="usa-checkbox">
                <input
                  class="usa-checkbox__input usa-checkbox__input--tile"
                  type="checkbox"
                  name="household_archetypes[]"
                  id="household_archetype_<%= archetype_key %>"
                  value="<%= archetype_key %>"
                  <%= "checked" if Launcher::HouseholdScenario.default_archetype_keys.include?(archetype_key) %>
                  data-action="advanced-launcher#selectHouseholdArchetype">
                <label class="usa-checkbox__label" for="household_archetype_<%= archetype_key %>">
                  <strong><%= t(".household.archetypes.#{archetype_key}.title") %></strong>
                  <span class="advanced-launcher__scenario-desc"><%= t(".household.archetypes.#{archetype_key}.description") %></span>
                </label>
              </div>
            <% end %>
            </div>
          </div>

          <div data-advanced-launcher-target="individualConfiguration">
            <div class="usa-accordion usa-accordion--bordered usa-accordion--multiselectable" data-allow-multiple>
              <h4 class="usa-accordion__heading">
                <button type="button" class="usa-accordion__button"
                        id="nsc-test-scenarios-button"
                        aria-expanded="false"
                        aria-controls="nsc-test-scenarios-content">
                  NSC Test Scenarios
                </button>
              </h4>
              <div id="nsc-test-scenarios-content" class="usa-accordion__content" aria-labelledby="nsc-test-scenarios-button">
                <div class="advanced-launcher__scenario-radios">
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_lynette" value="lynette"
                     data-action="advanced-launcher#selectScenario"
                     data-reporting-window-months="2">
              <label class="usa-radio__label" for="test_scenario_lynette">
                <strong>Lynette Oyola</strong>
                <span class="advanced-launcher__scenario-desc">Currently enrolled (1 school)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_rick" value="rick"
                     data-action="advanced-launcher#selectScenario"
                     data-reporting-window-months="2">
              <label class="usa-radio__label" for="test_scenario_rick">
                <strong>Rick Banas</strong>
                <span class="advanced-launcher__scenario-desc">Enrolled half-time (2 schools)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_dominique" value="dominique"
                     data-action="advanced-launcher#selectScenario"
                     data-reporting-window-months="2">
              <label class="usa-radio__label" for="test_scenario_dominique">
                <strong>Dominique Ricardo</strong>
                <span class="advanced-launcher__scenario-desc">Not currently enrolled (enrollments outside window)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_linda" value="linda"
                     data-action="advanced-launcher#selectScenario">
              <label class="usa-radio__label" for="test_scenario_linda">
                <strong>Linda Cooper</strong>
                <span class="advanced-launcher__scenario-desc">No NSC record found</span>
              </label>
            </div>

                </div>
              </div>

              <h4 class="usa-accordion__heading">
                <button type="button" class="usa-accordion__button"
                        id="fake-test-scenarios-button"
                        aria-expanded="false"
                        aria-controls="fake-test-scenarios-content">
                  Fake Test Scenarios
                </button>
              </h4>
              <div id="fake-test-scenarios-content" class="usa-accordion__content" aria-labelledby="fake-test-scenarios-button">
                <div class="advanced-launcher__scenario-radios">
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_partial_enrollment_sam" value="partial_enrollment_sam"
                     data-action="advanced-launcher#selectScenario">
              <label class="usa-radio__label" for="test_scenario_partial_enrollment_sam">
                <strong>Sam Testuser</strong>
                <span class="advanced-launcher__scenario-desc">Less-than-half-time enrollment (2 schools)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_partial_enrollment_multi_term" value="partial_enrollment_multi_term"
                     data-action="advanced-launcher#selectScenario">
              <label class="usa-radio__label" for="test_scenario_partial_enrollment_multi_term">
                <strong>Nina Testuser</strong>
                <span class="advanced-launcher__scenario-desc">Less-than-half-time enrollment, 2 terms (coverage depends on selected reporting window)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_partial_enrollment_ziggy" value="partial_enrollment_ziggy"
                     data-action="advanced-launcher#selectScenario">
              <label class="usa-radio__label" for="test_scenario_partial_enrollment_ziggy">
                <strong>Ziggy Testuser</strong>
                <span class="advanced-launcher__scenario-desc">Less-than-half-time enrollment (1 school)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_partial_enrollment_casey" value="partial_enrollment_casey"
                     data-action="advanced-launcher#selectScenario">
              <label class="usa-radio__label" for="test_scenario_partial_enrollment_casey">
                <strong>Casey Testuser</strong>
                <span class="advanced-launcher__scenario-desc">Mixed enrollment statuses (half-time + less-than-half-time)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_partial_enrollment_taylor" value="partial_enrollment_taylor"
                     data-action="advanced-launcher#selectScenario">
              <label class="usa-radio__label" for="test_scenario_partial_enrollment_taylor">
                <strong>Taylor Testuser</strong>
                <span class="advanced-launcher__scenario-desc">Mixed enrollment statuses (half-time only covers part of the reporting window)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_renewal_half_time_last_4_of_6_avery" value="renewal_half_time_last_4_of_6_avery"
                     data-action="advanced-launcher#selectScenario">
              <label class="usa-radio__label" for="test_scenario_renewal_half_time_last_4_of_6_avery">
                <strong>Avery Testuser</strong>
                <span class="advanced-launcher__scenario-desc">Half-time enrollment covering 4 of 6 months (for renewal required-month testing)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_partial_enrollment_maya" value="partial_enrollment_maya"
                     data-action="advanced-launcher#selectScenario">
              <label class="usa-radio__label" for="test_scenario_partial_enrollment_maya">
                <strong>Maya Testuser</strong>
                <span class="advanced-launcher__scenario-desc">Less-than-half-time enrollment (same school in multiple terms)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_summer_term_carryover_sage" value="summer_term_carryover_sage"
                     data-action="advanced-launcher#selectScenario"
                     data-reporting-window-start="07/01/2025"
                     data-reporting-window-months="4">
              <label class="usa-radio__label" for="test_scenario_summer_term_carryover_sage">
                <strong>Sage Testuser</strong>
                <span class="advanced-launcher__scenario-desc">Spring carryover for summer months (pick a summer reporting window)</span>
              </label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio"
                     name="test_scenario" id="test_scenario_spring_fall_no_summer_morgan" value="spring_fall_no_summer_morgan"
                     data-action="advanced-launcher#selectScenario"
                     data-reporting-window-start="06/01/2025"
                     data-reporting-window-months="4">
              <label class="usa-radio__label" for="test_scenario_spring_fall_no_summer_morgan">
                <strong>Morgan Testuser</strong>
                <span class="advanced-launcher__scenario-desc">Spring and fall enrollment with no summer term</span>
              </label>
            </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
      <hr class="advanced-launcher__mobile-divider">
      <div class="advanced-launcher__settings">
        <h2><%= t(".settings.title") %></h2>
        <%= render AdvancedLauncher::SettingComponent.new(title: "Flow type", hint: "Select which Emmy flow to launch.") do %>
          <div class="advanced-launcher__flow-type-radios">
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio" name="flow_type" id="flow_type_activity" value="activity" checked data-action="advanced-launcher#selectFlowType">
              <label class="usa-radio__label" for="flow_type_activity">CE</label>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio" name="flow_type" id="flow_type_cbv" value="cbv" data-advanced-launcher-target="incomeFlowRadio" data-action="advanced-launcher#selectFlowType">
              <label class="usa-radio__label" for="flow_type_cbv">Income</label>
            </div>
          </div>
        <% end %>
        <%= render AdvancedLauncher::SettingComponent.new(title: "Agency", hint: "Select the agency the flow will use.") do %>
          <select class="usa-select" name="client_agency_id" id="client_agency_id" data-action="change->advanced-launcher#selectAgency">
            <% Rails.application.config.client_agencies.client_agency_ids.each do |agency_id| %>
              <option value="<%= agency_id %>" <%= "selected" if agency_id == "sandbox" %>><%= agency_id %></option>
            <% end %>
          </select>
        <% end %>
        <div data-advanced-launcher-target="ceOnly">
          <%= render AdvancedLauncher::SettingComponent.new(title: "Reporting window", hint: "Select the type of flow you want to create. This determines the number of months in the reporting window.") do %>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio" name="reporting_window" id="reporting_window_application" value="application" <%= "checked" unless params[:reporting_window] == "renewal" %> data-action="advanced-launcher#selectWindow">
              <label class="usa-radio__label" for="reporting_window_application">Application</label>
            </div>
            <div data-advanced-launcher-target="monthButtons" class="advanced-launcher__month-buttons margin-top-1">
              <button type="button" class="usa-button" data-months="1" data-action="advanced-launcher#selectMonths">1 month</button>
              <button type="button" class="usa-button" data-months="2" data-action="advanced-launcher#selectMonths">2 months</button>
              <button type="button" class="usa-button" data-months="3" data-action="advanced-launcher#selectMonths">3 months</button>
              <div class="usa-hint advanced-launcher__month-buttons-hint">The application reporting window is configurable by the state.</div>
            </div>
            <div class="usa-radio">
              <input class="usa-radio__input usa-radio__input--tile" type="radio" name="reporting_window" id="reporting_window_renewal" value="renewal" <%= "checked" if params[:reporting_window] == "renewal" %> data-action="advanced-launcher#selectWindow">
              <label class="usa-radio__label" for="reporting_window_renewal">Renewal</label>
            </div>
            <div class="advanced-launcher__renewal-required margin-top-2 <%= "advanced-launcher__renewal-required--hidden" unless params[:reporting_window] == "renewal" %>" data-advanced-launcher-target="renewalRequiredField">
              <div class="advanced-launcher__inline-field">
                <input class="usa-input usa-input--sm" type="number" name="renewal_required_months"
                       id="renewal_required_months" min="1" max="6" autocomplete="off"
                       value="<%= params[:renewal_required_months] %>">
                <span>renewal months required</span>
                <span class="advanced-launcher__hint-toggle" data-action="click->advanced-launcher#toggleInlineHint"><svg class="usa-icon" aria-hidden="true" focusable="false" role="img"><use href="<%= asset_path("@uswds/uswds/dist/img/sprite.svg#info") %>"></use></svg></span>
              </div>
              <div class="usa-hint advanced-launcher__setting-hint" hidden>
                Optional. For renewal flows, override how many months must meet requirements (N of M).
              </div>
            </div>
            <div class="usa-hint advanced-launcher__separator">-- or --</div>
            <div class="advanced-launcher__inline-field">
              <input class="usa-input usa-input--sm" type="number" name="reporting_window_months"
                     id="reporting_window_months" min="1" max="99" autocomplete="off"
                     value="<%= params[:reporting_window_months] %>"
                     data-advanced-launcher-target="monthsInput">
              <span>months</span>
              <span class="advanced-launcher__hint-toggle" data-action="click->advanced-launcher#toggleInlineHint"><svg class="usa-icon" aria-hidden="true" focusable="false" role="img"><use href="<%= asset_path("@uswds/uswds/dist/img/sprite.svg#info") %>"></use></svg></span>
            </div>
            <div class="usa-hint advanced-launcher__setting-hint" hidden>
              Specify the reporting window manually.
            </div>
          <% end %>
          <%= render AdvancedLauncher::SettingComponent.new(
            title: "Reporting window start",
            hint: "Specify when the reporting window begins. When set, the window runs forward from the beginning of the selected month. Leave blank to use the default (window ends at the latest completed month)."
          ) do %>
            <div class="usa-date-picker" data-advanced-launcher-target="datePickerWrapper">
              <input
                class="usa-input"
                type="text"
                name="reporting_window_start"
                id="reporting_window_start"
                autocomplete="off"
              >
            </div>
          <% end %>
        </div>
        <%= render AdvancedLauncher::SettingComponent.new(title: "Session timeout", hint: "Specify the number of minutes it should take for the session to time out. Note: the warning modal appears 5 min before timeout, so use 6 or higher to avoid an immediate warning.") do %>
          <div class="advanced-launcher__inline-field">
            <input class="usa-input usa-input--sm" type="number" name="launcher_timeout"
                   id="launcher_timeout" min="1" max="999" autocomplete="off"
                   value="<%= params[:launcher_timeout] || 30 %>">
            <span>minutes</span>
          </div>
        <% end %>
      </div>
    </div>

    <section class="advanced-launcher__launch-section">
      <h2>Launch</h2>
      <p class="usa-hint">Generate a tokenized or generic link, then copy it or open it in a new tab.</p>
      <div class="advanced-launcher__launch-buttons">
        <fieldset class="usa-fieldset">
          <legend class="usa-legend">Link type</legend>
          <div class="advanced-launcher__link-type-row">
            <div class="advanced-launcher__link-type-radios">
              <div class="usa-radio">
                <input class="usa-radio__input usa-radio__input--tile" type="radio"
                       name="launch_type" id="launch_type_tokenized" value="tokenized" checked>
                <label class="usa-radio__label" for="launch_type_tokenized">Tokenized</label>
              </div>
              <div class="usa-radio">
                <input class="usa-radio__input usa-radio__input--tile" type="radio"
                       name="launch_type" id="launch_type_generic" value="generic"
                       data-advanced-launcher-target="genericLinkType">
                <label class="usa-radio__label" for="launch_type_generic">Generic</label>
              </div>
            </div>
            <button
              type="button"
              class="usa-button advanced-launcher__launch-button"
              data-action="advanced-launcher#copyShareLink"
              data-advanced-launcher-target="copyLaunchButton">
              Copy link
            </button>
            <button
              type="button"
              class="usa-button usa-button--outline advanced-launcher__launch-button"
              data-action="advanced-launcher#openShareLink"
              data-advanced-launcher-target="openLaunchButton">
              Open in new tab
            </button>
          </div>
        </fieldset>
      </div>
    </section>
  <% end %>
</div>
