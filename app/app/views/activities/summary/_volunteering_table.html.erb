<%= render(TableComponent.new) do |table| %>
  <%= table.with_header_cell(scope: "col") { t("shared.table_headers.community_service_information") } %>
  <%= table.with_header_cell(scope: "col") { t("shared.table_headers.your_details") } %>
  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.summary.community_service.organization") %>
    <% end %>
    <%= row.with_data_cell(data_label: t("activities.summary.community_service.organization")) do %>
      <%= activity.organization_name %>
    <% end %>
  <% end %>

  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.summary.community_service.address") %>
    <% end %>
    <%= row.with_data_cell(data_label: t("activities.summary.community_service.address")) do %>
      <%= activity.formatted_address.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.summary.community_service.coordinator_name") %>
    <% end %>
    <%= row.with_data_cell(data_label: t("activities.summary.community_service.coordinator_name")) do %>
      <%= activity.coordinator_name.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.summary.community_service.coordinator_email") %>
    <% end %>
    <%= row.with_data_cell(data_label: t("activities.summary.community_service.coordinator_email")) do %>
      <%= activity.coordinator_email.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.summary.community_service.coordinator_phone") %>
    <% end %>
    <%= row.with_data_cell(data_label: t("activities.summary.community_service.coordinator_phone")) do %>
      <%= activity.coordinator_phone_number.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

<% end %>

<h3><%= t("activities.summary.monthly_details") %></h3>
<%= render(TableComponent.new(activity_hours_review: true)) do |table| %>
  <%= table.with_header_cell(is_header: true, scope: "col") { t("activities.summary.community_service.month") } %>
  <%= table.with_header_cell(is_header: true, scope: "col") { t("activities.summary.community_service.hours_served") } %>
  <% activity.activity_months.order(month: :asc).each do |activity_month| %>
    <%= table.with_row do |row| %>
      <%= row.with_data_cell(data_label: t("activities.summary.community_service.month"), is_header: true)
             .with_content(I18n.l(activity_month.month, format: :month)) %>
      <%= row.with_data_cell(data_label: t("activities.summary.community_service.hours_served"))
             .with_content(activity_month.hours) %>
    <% end %>
  <% end %>
<% end %>

<% if activity.document_uploads.any? %>
  <%= render DocumentUploadsComponent.new(
    documents: activity.document_uploads.map { |a| { filename: a.filename.to_s } },
    heading_level: 3,
    full_width: true
  ) %>
<% end %>
