<% if activity.fully_self_attested? %>
  <%= render "activities/summary/fully_self_attested_education_table", activity: activity %>
<% elsif activity.partially_self_attested? %>
  <%= render "activities/summary/partially_self_attested_education_table", activity: activity %>
<% else %>
  <% activity.nsc_enrollment_terms.each do |enrollment_term| %>
    <%= render(EnrollmentTermTableComponent.new(nsc_enrollment_term: enrollment_term)) %>
  <% end %>
<% end %>
