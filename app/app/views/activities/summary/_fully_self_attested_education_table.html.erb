<%= render(TableComponent.new) do |table| %>
  <%= table.with_header_cell(scope: "col") { t("shared.table_headers.education_information") } %>
  <%= table.with_header_cell(scope: "col") { t("shared.table_headers.your_details") } %>
  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.summary.education.school_name") %>
    <% end %>
    <%= row.with_data_cell do %>
      <%= activity.school_name.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.summary.education.address") %>
    <% end %>
    <%= row.with_data_cell do %>
      <%= activity.formatted_address.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.summary.education.contact_name") %>
    <% end %>
    <%= row.with_data_cell do %>
      <%= activity.contact_name.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.summary.education.contact_email") %>
    <% end %>
    <%= row.with_data_cell do %>
      <%= activity.contact_email.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.summary.education.contact_phone") %>
    <% end %>
    <%= row.with_data_cell do %>
      <%= activity.contact_phone_number.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

<% end %>

<h3><%= t("activities.summary.education.term_details") %></h3>
<%= render(TableComponent.new) do |table| %>
  <%= table.with_header_cell(is_header: true, scope: "col") { t("activities.summary.education.month") } %>
  <%= table.with_header_cell(is_header: true, scope: "col") { t("activities.summary.education.credit_hours") } %>
  <%= table.with_header_cell(is_header: true, scope: "col") { t("activities.summary.education.community_engagement_hours") } %>
  <% activity.education_activity_months.order(:month).each do |activity_month| %>
    <%= table.with_row do |row| %>
      <%= row.with_data_cell(data_label: t("activities.summary.education.month"), is_header: true)
             .with_content(I18n.l(activity_month.month, format: :month_year)) %>
      <%= row.with_data_cell(data_label: t("activities.summary.education.credit_hours"))
             .with_content(format_decimal_amount(activity_month.hours)) %>
      <%= row.with_data_cell(data_label: t("activities.summary.education.community_engagement_hours"))
             .with_content(format_decimal_amount(activity.community_engagement_hours(activity_month.hours))) %>
    <% end %>
  <% end %>
<% end %>
