<%= render(TableComponent.new(is_responsive: true)) do |table| %>
  <%= table.with_subheader_row(class_names: "subheader-row base-lightest border-top-1px") do |row| %>
    <% row.with_data_cell(is_header: true).with_content(t("activities.summary.job_training.header")) %>
    <% row.with_data_cell(is_header: true).with_content(t("activities.summary.your_details")) %>
  <% end %>
  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.summary.job_training.program_name") %>
    <% end %>
    <%= row.with_data_cell do %>
      <%= activity.program_name %>
    <% end %>
  <% end %>

  <% if activity.organization_address.present? %>
    <%= table.with_row do |row| %>
      <%= row.with_data_cell(is_header: true) do %>
        <%= t("activities.summary.job_training.organization_address") %>
      <% end %>
      <%= row.with_data_cell do %>
        <%= activity.organization_address %>
      <% end %>
    <% end %>
  <% end %>

  <% month_hours_rows = activity.job_training_activity_months.order(:month) %>
  <% if month_hours_rows.empty? %>
    <%= table.with_row do |row| %>
      <%= row.with_data_cell(is_header: true) do %>
        <%= t("activities.summary.job_training.month") %>
      <% end %>
      <%= row.with_data_cell do %>
        <%= t("shared.not_applicable") %>
      <% end %>
    <% end %>
  <% end %>

  <% month_hours_rows.each do |month_hours| %>
    <%= table.with_row do |row| %>
      <%= row.with_data_cell(is_header: true) do %>
        <%= t("activities.summary.job_training.month") %>
      <% end %>
      <%= row.with_data_cell do %>
        <%= I18n.l(month_hours.month, format: :month) %>
      <% end %>
    <% end %>

    <%= table.with_row do |row| %>
      <%= row.with_data_cell(is_header: true) do %>
        <%= t("activities.summary.job_training.hours_attended") %>
      <% end %>
      <%= row.with_data_cell do %>
        <%= month_hours.hours %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
