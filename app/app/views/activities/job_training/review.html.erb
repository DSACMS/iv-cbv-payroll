<% content_for :title, t("activities.work_programs.review.title", program_name: @job_training_activity.program_name) %>

<% content_for :activity_flow_header do %>
  <%= render ActivityFlowHeaderComponent.new(
    title: t("activities.work_programs.title_singular"),
    exit_url: activities_flow_root_path,
    back_url: @back_url
  ) %>
<% end %>

<h1>
  <%= t("activities.work_programs.review.title", program_name: @job_training_activity.program_name) %>
</h1>
<p>
  <%= t("activities.work_programs.review.description", program_name: @job_training_activity.program_name) %>
</p>

<div class="display-flex flex-justify activity-review-edit-header">
  <h2 class="margin-y-0"><%= t("activities.work_programs.review.organization_info") %></h2>
  <%= link_to t("activities.hub.edit"),
        edit_activities_flow_job_training_path(id: @job_training_activity, from_review: 1, from_edit: params[:from_edit].presence),
        class: "usa-link" %>
</div>
<%= render(TableComponent.new(is_responsive: true, class_names: "activity-review-table", thead_class_names: "")) do |table| %>
  <%= table.with_header_cell(scope: "col") { t("shared.table_headers.work_program_information") } %>
  <%= table.with_header_cell(scope: "col") { t("shared.table_headers.your_details") } %>
  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.work_programs.review.organization_name") %>
    <% end %>
    <%= row.with_data_cell do %>
      <%= @job_training_activity.organization_name.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.work_programs.review.program_name") %>
    <% end %>
    <%= row.with_data_cell do %>
      <%= @job_training_activity.program_name.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.work_programs.review.address") %>
    <% end %>
    <%= row.with_data_cell do %>
      <%= @job_training_activity.formatted_address.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.work_programs.review.contact_name") %>
    <% end %>
    <%= row.with_data_cell do %>
      <%= @job_training_activity.contact_name.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.work_programs.review.contact_email") %>
    <% end %>
    <%= row.with_data_cell do %>
      <%= @job_training_activity.contact_email.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>

  <%= table.with_row do |row| %>
    <%= row.with_data_cell(is_header: true) do %>
      <%= t("activities.work_programs.review.contact_phone") %>
    <% end %>
    <%= row.with_data_cell do %>
      <%= @job_training_activity.contact_phone_number.presence || t("shared.not_applicable") %>
    <% end %>
  <% end %>
<% end %>

<h2><%= t("activities.work_programs.review.hours_section") %></h2>
<%= render(TableComponent.new(is_responsive: true, class_names: "activity-review-hours-table")) do |table| %>
  <%= table.with_subheader_row(class_names: "subheader-row base-lightest") do |row| %>
    <%= row.with_data_cell(is_header: true, class_names: "text-nowrap")
           .with_content(t("activities.summary.job_training.month")) %>
    <%= row.with_data_cell(is_header: true, class_names: "text-nowrap")
           .with_content(t("activities.work_programs.review.work_program_hours")) %>
    <%= row.with_data_cell(is_header: true, class_names: "text-nowrap")
           .with_content(t("activities.work_programs.review.edit")) %>
  <% end %>
  <% @job_training_activity.job_training_activity_months.order(:month).each_with_index do |activity_month, index| %>
    <% edit_path = edit_activities_flow_job_training_month_path(job_training_id: @job_training_activity, id: index, from_review: 1, from_edit: params[:from_edit].presence) %>
    <%= table.with_row do |row| %>
      <%= row.with_data_cell(data_label: t("activities.summary.job_training.month"), is_header: true) do %>
        <%= I18n.l(activity_month.month, format: :month) %>
        <%= link_to t("activities.work_programs.review.edit"), edit_path, class: "usa-link mobile-edit-link" %>
      <% end %>
      <%= row.with_data_cell(data_label: t("activities.work_programs.review.work_program_hours"))
             .with_content(activity_month.hours) %>
      <%= row.with_data_cell(class_names: "desktop-edit-link") do %>
        <%= link_to t("activities.work_programs.review.edit"), edit_path, class: "usa-link" %>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<%= form_with model: @job_training_activity,
      url: save_review_activities_flow_job_training_path(id: @job_training_activity, from_edit: params[:from_edit].presence),
      method: :patch,
      class: "usa-form usa-form--large" do |form| %>
  <h2><%= t("activities.work_programs.review.additional_comments_title") %></h2>
  <%= form.label :additional_comments,
        t("activities.work_programs.review.additional_comments_description",
          agency_name: agency_translation("shared.agency_full_name")),
        class: "usa-label" %>
  <%= form.text_area :additional_comments, class: "usa-textarea", rows: 5 %>

  <% submit_label = params[:from_edit].present? ? t("activities.hub.save") : t("activities.work_programs.review.save") %>
  <%= form.submit submit_label, class: "usa-button usa-button--primary" %>
<% end %>
