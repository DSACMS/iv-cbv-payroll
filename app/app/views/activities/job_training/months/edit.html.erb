<% content_for :activity_flow_header do %>
  <%= render ActivityFlowHeaderComponent.new(
    title: t("activities.work_programs.title_singular"),
    exit_url: activities_flow_root_path,
    back_url: @back_url
  ) %>
<% end %>

<% from_review = params[:from_review].present? %>
<% from_edit = params[:from_edit].present? %>
<%= render "shared/hours_input",
    activity_month: @activity_month,
    form_url: activities_flow_job_training_month_path(job_training_id: @job_training_activity, id: @month_index, from_review: from_review ? 1 : nil, from_edit: from_edit ? 1 : nil),
    activity_name: @job_training_activity.program_name,
    current_month: @current_month,
    months: @months,
    month_index: @month_index,
    error: @error,
    t_scope: "activities.work_programs.hours_input",
    submit_label: from_review ? t("activities.hub.save") : nil %>
