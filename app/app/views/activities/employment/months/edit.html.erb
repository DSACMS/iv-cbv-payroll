<% from_review = params[:from_review].present? %>
<% from_edit = params[:from_edit].present? %>
<%= render "shared/hours_input",
    activity_month: @activity_month,
    form_url: activities_flow_income_employment_month_path(employment_id: @employment_activity, id: @month_index, from_review: from_review ? 1 : nil, from_edit: from_edit ? 1 : nil),
    activity_name: @employment_activity.employer_name,
    current_month: @current_month,
    months: @months,
    month_index: @month_index,
    error: @error,
    t_scope: "activities.employment.hours_input",
    title: t("activities.employment.hours_input.heading",
      month: l(@current_month, format: :month_year),
      organization: @employment_activity.employer_name),
    submit_label: from_review ? t("activities.hub.save") : nil,
    show_gross_income: true %>
