<% content_for :title, t(".title") %>
<h1><%= t(".title") %></h1>

<p>
  <%= t(".description") %>
</p>

<ol>
  <li><%= t(".option_1") %></li>
  <li><%= t(".option_2") %></li>
  <li><%= t(".option_3", agency_acronym: agency_translation("shared.agency_acronym")) %></li>
  <% if @cbv_flow.has_account_with_required_data? %>
    <li><%= t("cbv.missing_results.show.continue_to_review", agency_acronym: agency_translation("shared.agency_acronym")) %></li>
  <% end %>
</ol>

<ul class="usa-button-group margin-top-5">
  <li class="usa-button-group__item margin-bottom-0">
    <%= link_to t(".back_to_search"), @back_to_search_path, class: "usa-button usa-button--outline" %>
  </li>
  <li class="usa-button-group__item margin-bottom-0">
    <% case @flow %>
    <% when CbvFlow %>
      <% if @cbv_flow.has_account_with_required_data? %>
        <%= link_to t(".continue_to_report"), cbv_flow_other_job_path, class: "usa-button" %>
      <% else %>
        <%= agency_translation("cbv.expired_invitations.show.cta_button_html", agency_url: agency_url) %>
      <% end %>
    <% when ActivityFlow %>
      <%= link_to t("cbv.employer_searches.show.activity_flow.add_employment_manually"), new_activities_flow_income_employment_path, class: "usa-button", data: { turbo_frame: "_top" } %>
    <% end %>
  </li>
</ul>
