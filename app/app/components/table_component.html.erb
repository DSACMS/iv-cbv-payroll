<%= tag.table(**@attributes.merge(class: @class_names)) do %>
  <thead class="<%= @thead_class_names %>">
    <% if header.present? %>
      <tr>
        <%= header %>
      </tr>
    <% elsif header_cells.any? %>
      <tr>
        <% header_cells.each { |cell| concat(cell) } %>
      </tr>
    <% end %>
  </thead>
  <tbody>
    <% rows.each do |row| %>
      <%= row %>
    <% end %>
  </tbody>
<% end %>
