<%= render(TableRowComponent.new(highlight: @highlight)) do |row| -%>
  <%= row.with_data_cell(is_header: true, class_names: @field[:label_class_names]) do -%>
    <%= @field[:label] || "" -%>
  <%- end -%>
  <%= row.with_data_cell(data_label: @field[:label]) do -%>
    <%= @field[:value] || "" %>
  <%- end -%>
<%- end -%>
