#!/bin/bash

set -euo pipefail

app_name="$1"
image_name="$2"
image_tag="$3"
image_repo="$4"

echo "---------------"
echo "Publish release to ECR"
echo "---------------"
echo "Input parameters:"
echo "  app_name=${app_name}"
echo "  image_name=${image_name}"
echo "  image_tag=${image_tag}"
echo "  image_repo=${image_repo}"

if [[ -z "${image_repo}" ]]; then
  echo "Error: image_repo is required for ECR publish"
  exit 1
fi

# In ECR, the image_repo usually includes the repository name, 
# but let's stick to the pattern from publish-release-artifactory 
# if the user wants a "brand" of it.
# Actually, if image_repo is something like 123456789012.dkr.ecr.us-east-1.amazonaws.com/my-repo
# then the tag should probably just be ${image_repo}:${image_tag} 
# BUT publish-release-artifactory does ${image_repo}/${image_name}:${image_tag}

ecr_image="${image_repo}:${image_tag}"

echo "Tagging image: ${image_name}:${image_tag} -> ${ecr_image}"
docker tag "${image_name}:${image_tag}" "${ecr_image}"

echo "Pushing image to ECR: ${ecr_image}"
docker push "${ecr_image}"

echo "Successfully published to ECR"
