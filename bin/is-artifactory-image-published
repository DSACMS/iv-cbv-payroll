#!/usr/bin/env bash
# Checks if an image tag has already been published to Artifactory.
# Prints "true" if so, "false" otherwise.

set -euo pipefail

image_tag="$1"

if docker manifest inspect \
          "artifactory.cloud.cms.gov/emmy-docker/emmy-app:${image_tag}" &>/dev/null ; then
    echo "true"
else
    echo "false"
fi
